# CDAA local development environment
# Copy to .env and fill in real values before running tests.
# Secrets marked CHANGE_ME must be set manually; others have safe defaults for localstack.

# ---------------------------------------------------------------------------
# Terraform variables (used by terraform.tfvars.localstack or as overrides)
# ---------------------------------------------------------------------------

# Prefix for all AWS resource names (DynamoDB table, Lambda functions, SSM paths, etc.)
TF_VAR_name_prefix=cdaa-test

# AWS account ID used in ARNs and IAM policies
TF_VAR_account_id=123456789012

# AWS region for localstack (community edition runs everything in us-east-1)
TF_VAR_aws_region=us-east-1

# Jira project key for violation tickets
TF_VAR_jira_project_key=PROJ

# Name of the Jira connector Lambda invoked by daily_reconciliation
# For localstack, points at the in-process jira-stub Lambda
TF_VAR_jira_connector_function_name=cdaa-test-jira-stub

# CloudWatch log group name for PostgreSQL RDS audit logs
TF_VAR_rds_postgresql_loggroup_name=/aws/rds/instance/test-db/postgresql

# CloudWatch log group name for Vault audit logs
TF_VAR_vault_audit_loggroup_name=/vault/audit

# Comma-separated list of database names to scope audit log forwarding
TF_VAR_database_audit_filter=example_prod_db

# CloudTrail Lake native event data store ID
# For localstack, any non-empty string works (service is not supported in community edition)
TF_VAR_cloudtrail_lake_event_data_store_id=test-native-store-id

# CloudTrail Lake curated event data store ID (same note as above)
TF_VAR_cloudtrail_lake_curated_store_id=test-curated-store-id

# CloudTrail channel ARN used by the CTL forwarder Lambda
# For localstack, any non-empty string works
TF_VAR_cloudtrail_channel_arn=test-channel-arn

# Customer data resources as JSON (S3 bucket and RDS database ARNs to audit)
TF_VAR_customer_data_config={"s3_buckets":[],"rds_databases":[]}

# Python runtime for Lambda functions
# Must match the Lambda base image used by localstack
TF_VAR_lambda_runtime=python3.12

# Local timezone for date calculations and reconciliation windows
TF_VAR_local_timezone=Europe/Berlin

# ---------------------------------------------------------------------------
# SSM parameter values (written by conftest.py fixtures into localstack SSM)
# Must be set manually in real AWS after `terraform apply`; CHANGE_ME is the
# Terraform placeholder and the Lambda will refuse to start if it is unchanged.
# ---------------------------------------------------------------------------

# Slack app signing secret - used to verify request signatures from Slack
# Real value: Settings > Basic Information > App Credentials in api.slack.com
SSM_SLACK_SIGNING_SECRET=CHANGE_ME

# Slack bot OAuth token - used to call Slack API (open modals, send messages)
# Real value: OAuth & Permissions > Bot User OAuth Token in api.slack.com
SSM_SLACK_BOT_TOKEN=xoxb-CHANGE_ME

# Comma-separated allowed access durations in minutes
SSM_ALLOWED_DURATIONS=15,30,60

# Customer data config JSON (mirrors TF_VAR_customer_data_config; SSM is the runtime source)
SSM_CUSTOMER_DATA_CONFIG={"s3_buckets":["arn:aws:s3:::example-data-bucket"],"rds_databases":["arn:aws:rds:us-east-1:123456789012:db:example-prod"]}

# JSON array of database usernames excluded from audit (service accounts, migrations, etc.)
SSM_WHITELIST_DB_USERS=[]

# JSON object of S3 actors excluded from audit, keyed by category
# Example: {"SERVICE_PRINCIPAL":["s3-metadata-handler"],"IAM_ROLE":["backup-role"]}
SSM_WHITELIST_S3_ACTORS={}

# Enable Jira ticket creation for detected violations (true/false)
SSM_JIRA_REPORTING_ENABLED=true

# ---------------------------------------------------------------------------
# Integration test settings
# ---------------------------------------------------------------------------

# Host reachable from inside Docker Lambda containers for the CloudTrail Lake
# and Jira HTTP mock servers (ports 9090 and 9091).
# Mac/Windows Docker Desktop: leave as default (host.docker.internal is auto-resolved).
# Linux: set to the Docker bridge gateway IP, e.g.:
#   export CTL_HTTPSERVER_HOST=$(ip route show default | awk '/default/{print $3}')
CTL_HTTPSERVER_HOST=host.docker.internal

# ---------------------------------------------------------------------------
# Docker socket (used by localstack LAMBDA_EXECUTOR=docker)
# ---------------------------------------------------------------------------

# Path to the Docker socket mounted into the localstack container.
# Default works on Mac and Linux with Docker Desktop.
# If using Colima or a non-standard socket path, override here.
DOCKER_HOST=unix:///var/run/docker.sock

# ---------------------------------------------------------------------------
# AWS credentials for localstack (boto3 requires non-empty values)
# ---------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
